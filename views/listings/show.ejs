<% layout("layouts/boilerplate") %>

<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@3.3.1/dist/maplibre-gl.css" />
<script src="https://unpkg.com/maplibre-gl@3.3.1/dist/maplibre-gl.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/starability/starability-all.min.css">

<%
  let coords = [77.2090, 28.6139];
  if (listing && listing.geometry && listing.geometry.coordinates) {
    coords = listing.geometry.coordinates;
  }

  let mapStyle = MAP_STYLE || "";
%>

<div class="container show-page page-shell">
  <div class="show-header">
    <p class="show-kicker">
      <i class="fa-solid fa-star"></i> 4.8 · Guest favorite · Hosted with care
    </p>

    <h1 class="show-title"><%= listing.title %></h1>

    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
      <p class="section-subtext mb-0">
        <i class="fa-solid fa-location-dot"></i>
        <%= listing.location %>, <%= listing.country %>
      </p>

      <span class="meta-pill">
        <i class="fa-solid fa-shield-heart"></i> Verified stay
      </span>

      <span class="meta-pill">
        <i class="fa-solid fa-bolt"></i> Quick booking
      </span>
    </div>
  </div>

  <div class="show-gallery-shell">
    <img
      src="<%= listing.image && listing.image.url ? listing.image.url : '' %>"
      class="show-main-image"
      alt="<%= listing.title %>"
    />

    <div class="show-floating-badges">
      <span class="show-float-pill">
        <i class="fa-solid fa-heart"></i> Guest favorite
      </span>
      <span class="show-float-pill">
        <i class="fa-solid fa-star"></i> 4.8 rating
      </span>
    </div>
  </div>

  <div class="row mt-4 g-4">
    <div class="col-lg-8">
      <div class="info-box mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
          <div>
            <h4 class="fw-bold mb-2">
              Hosted by @<%= listing.owner && listing.owner.username ? listing.owner.username : "Unknown" %>
            </h4>
            <p class="section-subtext mb-0">
              Premium stay experience with clean design, trusted hosting, and a polished booking flow.
            </p>
          </div>

          <div class="host-mini-card">
            <div class="host-mini-icon">
              <i class="fa-solid fa-user-check"></i>
            </div>
            <div>
              <strong>Super host vibes</strong>
              <p class="mb-0 text-muted small">Quick responses · curated property</p>
            </div>
          </div>
        </div>

        <div class="show-meta">
          <span class="meta-pill"><i class="fa-solid fa-house"></i> Entire place</span>
          <span class="meta-pill"><i class="fa-solid fa-users"></i> 4 guests</span>
          <span class="meta-pill"><i class="fa-solid fa-bed"></i> 2 bedrooms</span>
          <span class="meta-pill"><i class="fa-solid fa-bath"></i> 2 baths</span>
        </div>

        <div class="show-description-box">
          <h3 class="section-title mt-0">About this stay</h3>
          <p class="mb-0 show-description-text">
            <%= listing.description %>
          </p>
        </div>

        <div class="show-info-grid mt-4">
          <div class="show-info-card">
            <span class="show-info-label">Location</span>
            <h6><%= listing.location %>, <%= listing.country %></h6>
            <p>Prime destination with convenient access and better travel comfort.</p>
          </div>

          <div class="show-info-card">
            <span class="show-info-label">Price</span>
            <h6>₹ <%= listing.price.toLocaleString("en-IN") %> / night</h6>
            <p>Transparent pricing with modern booking and guest-first experience.</p>
          </div>
        </div>

        <h3 class="section-title">What this place offers</h3>
        <div class="amenities-grid">
          <div class="amenity-item"><i class="fa-solid fa-wifi"></i> Fast Wi-Fi</div>
          <div class="amenity-item"><i class="fa-solid fa-kitchen-set"></i> Kitchen access</div>
          <div class="amenity-item"><i class="fa-solid fa-square-parking"></i> Free parking</div>
          <div class="amenity-item"><i class="fa-solid fa-location-dot"></i> Prime location</div>
          <div class="amenity-item"><i class="fa-solid fa-tv"></i> Smart entertainment</div>
          <div class="amenity-item"><i class="fa-solid fa-shield-heart"></i> Secure stay</div>
        </div>

        <% if (currUser && listing.owner && listing.owner._id.toString() === currUser._id.toString()) { %>
          <div class="owner-actions">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary px-4">Edit listing</a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-danger rounded-pill px-4" type="submit">Delete listing</button>
            </form>
          </div>
        <% } %>
      </div>

      <div class="map-box mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
          <div>
            <h3 class="section-title mt-0 mb-1">Where you’ll be</h3>
            <p class="section-subtext mb-0">Explore the location visually with map support.</p>
          </div>
          <span class="meta-pill">
            <i class="fa-solid fa-location-crosshairs"></i> Live map
          </span>
        </div>
        <div id="showMap"></div>
      </div>

      <div class="review-section-shell">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
          <div>
            <h3 class="section-title mt-0 mb-1">Reviews</h3>
            <p class="section-subtext mb-0">Real feedback from guests who explored this stay.</p>
          </div>
          <span class="meta-pill">
            <i class="fa-solid fa-star"></i> Guest insights
          </span>
        </div>

        <% if (listing.reviews.length) { %>
          <div class="row gy-3">
            <% listing.reviews.forEach((r) => { %>
              <div class="col-md-6">
                <div class="card review-card p-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0 fw-bold">@<%= r.author && r.author.username ? r.author.username : "User" %></h6>
                    <span class="text-muted small">Verified guest</span>
                  </div>

                  <p class="starability-result mb-2" data-rating="<%= r.rating %>"></p>
                  <p class="mb-3 review-text"><%= r.comment %></p>

                  <% if (currUser) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= r._id %>?_method=DELETE">
                      <button class="btn btn-sm btn-outline-danger rounded-pill px-3" type="submit">Delete</button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state-sm">
            <h5>No reviews yet</h5>
            <p>Be the first guest to share your experience for this stay.</p>
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="show-side-sticky">
        <div class="booking-box mb-4">
          <div class="booking-top-strip">
            <span class="booking-top-pill">
              <i class="fa-solid fa-bolt"></i> Instant reserve
            </span>
            <span class="booking-top-pill">
              <i class="fa-solid fa-lock"></i> Secure booking
            </span>
          </div>

          <div class="price-big">
            ₹ <%= listing.price.toLocaleString("en-IN") %>
            <span class="fs-6 fw-semibold text-muted">/ night</span>
          </div>

          <p class="price-caption">
            Best value stay with premium comfort, professional presentation, and strong guest experience.
          </p>

          <form action="/listings/<%= listing._id %>/book" method="POST" class="booking-form">
            <div class="booking-input-grid">
              <div class="booking-field">
                <label class="form-label">Check-in</label>
                <input type="date" name="checkIn" class="form-control" required>
              </div>

              <div class="booking-field">
                <label class="form-label">Check-out</label>
                <input type="date" name="checkOut" class="form-control" required>
              </div>
            </div>

            <div class="booking-field mt-3">
              <label class="form-label">Guests</label>
              <input
                type="number"
                name="guests"
                min="1"
                value="1"
                class="form-control"
                required
              >
            </div>

            <button class="btn btn-primary py-3 fw-bold w-100 mt-3" type="submit">
              Reserve now
            </button>
          </form>

          <div class="d-grid gap-2 mt-3">
            <% if (currUser) { %>
              <form action="/listings/<%= listing._id %>/wishlist" method="POST">
                <button
                  class="btn <%= isWishlisted ? 'btn-dark' : 'btn-outline-dark' %> rounded-pill py-3 fw-bold w-100"
                  type="submit"
                  data-wishlist-btn="true"
                >
                  <%= isWishlisted ? 'Saved in wishlist' : 'Save to wishlist' %>
                </button>
              </form>
            <% } else { %>
              <a href="/login" class="btn btn-outline-dark rounded-pill py-3 fw-bold">Login to save</a>
            <% } %>
          </div>

          <hr>

          <div class="booking-cost-list">
            <div class="d-flex justify-content-between mb-2">
              <span>Cleaning fee</span>
              <strong>₹ 999</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Service fee</span>
              <strong>₹ 499</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Taxes</span>
              <strong>18%</strong>
            </div>
            <div class="d-flex justify-content-between booking-total-row">
              <span>Total before dates</span>
              <strong>₹ <%= (listing.price + 999 + 499).toLocaleString("en-IN") %></strong>
            </div>
          </div>
        </div>

        <div class="review-box">
          <% if(currUser) { %>
            <h4 class="fw-bold mb-3">Add a Review</h4>

            <form action="/listings/<%= listing._id %>/reviews" method="POST">
              <label class="form-label">Rating</label>

              <fieldset class="starability-slot mb-3">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked />
                <input type="radio" id="rate1" name="review[rating]" value="1" />
                <label for="rate1">1 star</label>
                <input type="radio" id="rate2" name="review[rating]" value="2" />
                <label for="rate2">2 stars</label>
                <input type="radio" id="rate3" name="review[rating]" value="3" />
                <label for="rate3">3 stars</label>
                <input type="radio" id="rate4" name="review[rating]" value="4" />
                <label for="rate4">4 stars</label>
                <input type="radio" id="rate5" name="review[rating]" value="5" />
                <label for="rate5">5 stars</label>
              </fieldset>

              <label class="form-label">Comment</label>
              <textarea
                name="review[comment]"
                rows="4"
                class="form-control mb-3"
                placeholder="Share your experience..."
                required
              ></textarea>

              <button class="btn btn-dark w-100 py-2 fw-bold" type="submit">Submit Review</button>
            </form>
          <% } else { %>
            <h5 class="fw-bold mb-2">Want to review this stay?</h5>
            <p class="text-muted mb-3">
              Login to share your experience and help other travelers choose better.
            </p>
            <a href="/login" class="btn btn-primary w-100 py-2 fw-bold">Login to review</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const coords = <%- JSON.stringify(coords) %>;
  const mapStyle = <%- JSON.stringify(mapStyle) %>;

  if (document.getElementById("showMap") && typeof maplibregl !== "undefined") {
    const map = new maplibregl.Map({
      container: "showMap",
      style: mapStyle,
      center: coords,
      zoom: 11
    });

    new maplibregl.Marker({ color: "#fe424d" })
      .setLngLat(coords)
      .addTo(map);
  }
</script>