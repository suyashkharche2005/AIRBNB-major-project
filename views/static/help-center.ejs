<% layout("layouts/boilerplate") %>

<div class="container policy-page">
  <section class="policy-hero">
    <span class="policy-pill">Help Center</span>
    <h1>Support & Help Center</h1>
    <p>
      Find guidance for account access, wishlist usage, booking flow, hosting,
      and general platform support for WanderLust.
    </p>
  </section>

  <section class="policy-grid">
    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-right-to-bracket"></i></div>
      <h3>Login and signup</h3>
      <p>
        Use the login and signup pages to access protected features like wishlist,
        dashboard, and booking-related user flow.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-regular fa-heart"></i></div>
      <h3>Wishlist support</h3>
      <p>
        Wishlist interactions require login. If redirected, sign in first and then
        continue saving or reviewing your shortlisted stays.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-calendar-check"></i></div>
      <h3>Booking flow</h3>
      <p>
        Choose your listing, review details, and continue through booking-ready
        steps with secure access and user-specific interaction.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-building"></i></div>
      <h3>Hosting and listings</h3>
      <p>
        Hosts can add listings, manage property details, and use dashboard features
        for platform activity and listing flow.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-envelope"></i></div>
      <h3>Contact support</h3>
      <p>
        For support or project-related queries:
        <br />
        <b style="color:#fe424d;">yashkharche20@gmail.com</b>
      </p>
    </div>
  </section>
</div>