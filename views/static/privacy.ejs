<% layout("layouts/boilerplate") %>

<div class="container policy-page">
  <section class="policy-hero">
    <span class="policy-pill">Privacy</span>
    <h1>Privacy Policy</h1>
    <p>
      WanderLust values user trust and protects account, listing, and booking-related information
      with modern SaaS-grade design and secure application flow.
    </p>
  </section>

  <section class="policy-grid">
    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-database"></i></div>
      <h3>Information we collect</h3>
      <p>
        We collect user account details such as username, email, login credentials,
        listing data, booking activity, and wishlist interactions.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-gears"></i></div>
      <h3>How data is used</h3>
      <p>
        Your data helps support authentication, listing management, booking flow,
        dashboard personalization, and user experience improvements.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-shield-halved"></i></div>
      <h3>Data protection</h3>
      <p>
        We use protected routes, secure login flow, and access control to keep user
        actions and information safer across the platform.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-user-lock"></i></div>
      <h3>User control</h3>
      <p>
        Users can manage their listings, wishlist data, and account-related actions
        through the platform experience.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-envelope"></i></div>
      <h3>Contact</h3>
      <p>
        For privacy-related queries, contact:
        <br />
        <b style="color:#fe424d;">yashkharche20@gmail.com</b>
      </p>
    </div>
  </section>
</div>