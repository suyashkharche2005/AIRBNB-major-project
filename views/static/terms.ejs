<% layout("layouts/boilerplate") %>

<div class="container policy-page">
  <section class="policy-hero">
    <span class="policy-pill">Terms</span>
    <h1>Terms & Conditions</h1>
    <p>
      These terms define how users interact with WanderLust, including accounts,
      listings, protected features, and booking-related actions.
    </p>
  </section>

  <section class="policy-grid">
    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-user-check"></i></div>
      <h3>User responsibility</h3>
      <p>
        Users should provide correct account information and interact with the
        platform responsibly while using listings and protected actions.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-house"></i></div>
      <h3>Listings and property use</h3>
      <p>
        Listings shown on WanderLust are part of the booking experience and should
        be reviewed carefully before taking further action.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-lock"></i></div>
      <h3>Protected features</h3>
      <p>
        Wishlist, dashboard, and some listing interactions may require login before
        users can continue their journey on the platform.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-code-branch"></i></div>
      <h3>Platform updates</h3>
      <p>
        WanderLust may change design, content, interaction flow, and product
        features to improve the overall user experience.
      </p>
    </div>

    <div class="policy-card">
      <div class="policy-icon"><i class="fa-solid fa-circle-info"></i></div>
      <h3>Acceptance</h3>
      <p>
        By continuing to use WanderLust, users agree to platform terms and the
        intended use of this booking-style web application.
      </p>
    </div>
  </section>
</div>  