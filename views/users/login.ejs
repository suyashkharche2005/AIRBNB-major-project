<% layout("layouts/boilerplate") %>

<div class="container auth-page-wrap">
  <div class="auth-shell">
    <div class="auth-visual">
      <div>
        <span class="auth-kicker">Welcome back</span>
        <h2>Log in to access your premium WanderLust experience.</h2>
        <p>
          WanderLust is built by Suyash as a polished Airbnb-style booking
          platform focused on premium UI, secure interaction flow, wishlist,
          dashboard access, and product-level user experience.
        </p>

        <div class="auth-feature-list">
          <div class="auth-feature">
            <i class="fa-regular fa-heart"></i>
            <div>
              <strong>Save favorites</strong>
              <p class="mb-0">Wishlist your preferred stays and revisit them anytime.</p>
            </div>
          </div>

          <div class="auth-feature">
            <i class="fa-solid fa-lock"></i>
            <div>
              <strong>Protected actions</strong>
              <p class="mb-0">Booking and interaction flows are secured through login.</p>
            </div>
          </div>

          <div class="auth-feature">
            <i class="fa-solid fa-chart-line"></i>
            <div>
              <strong>Dashboard ready</strong>
              <p class="mb-0">Track your account flow and manage your platform activity.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="auth-form-panel">
      <div class="auth-card">
        <div class="auth-card-head">
          <h3>Log in</h3>
          <p>Enter your details to continue.</p>
        </div>

        <form action="/login" method="POST" class="auth-form needs-validation" novalidate>
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input
              name="username"
              id="username"
              type="text"
              class="form-control"
              placeholder="Enter your username"
              required
            />
            <div class="invalid-feedback">Please enter username.</div>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input
              name="password"
              id="password"
              type="password"
              class="form-control"
              placeholder="Enter your password"
              required
            />
            <div class="invalid-feedback">Please enter password.</div>
          </div>

          <button class="btn btn-primary w-100 py-3 fw-bold mt-2" type="submit">
            Log in
          </button>
        </form>

        <div class="auth-switch">
          Don’t have an account?
          <a href="/signup">Create one</a>
        </div>

        <p class="auth-note">
          WanderLust is a premium full-stack project by Suyash built to demonstrate
          modern UI, user flow, and product-quality web development.
        </p>
      </div>
    </div>
  </div>
</div>