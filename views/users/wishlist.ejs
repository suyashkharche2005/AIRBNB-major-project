<% layout("layouts/boilerplate") %>

<div class="container page-shell">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
      <h1 class="section-heading mb-1">Your wishlist</h1>
      <p class="section-subtext mb-0">All your saved premium stays in one place.</p>
    </div>
    <a href="/listings" class="btn btn-outline-dark rounded-pill px-4">Explore more</a>
  </div>

  <% if (!wishlistListings.length) { %>
    <div class="info-box text-center py-5">
      <h4 class="fw-bold mb-2">No saved listings yet</h4>
      <p class="text-muted mb-3">Start saving places you love and build your dream stay collection.</p>
      <a href="/listings" class="btn btn-primary rounded-pill px-4">Browse listings</a>
    </div>
  <% } else { %>
    <div class="row row-cols-xl-3 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
      <% wishlistListings.forEach((listing) => { %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card h-100">
              <div class="card-img-wrap">
                <img
                  src="<%= listing.image.url %>"
                  class="card-img-top"
                  alt="listing_image"
                  style="height: 19rem;"
                />
              </div>

              <div class="card-body">
                <div class="card-title-row">
                  <h5 class="card-title"><%= listing.title %></h5>
                  <div class="card-rating">
                    <i class="fa-solid fa-star"></i> 4.8
                  </div>
                </div>
                <p class="card-location"><%= listing.location %>, <%= listing.country %></p>
                <div class="card-price">₹<%= listing.price.toLocaleString("en-IN") %> <span>/ night</span></div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>